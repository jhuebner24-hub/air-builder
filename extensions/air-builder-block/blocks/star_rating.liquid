<div id="air-builder">
  <div class="ab-wrap">
    <div class="ab-glass ab-vehicle">
      <div class="ab-vehicle-title">Select Your Vehicle</div>

      <div class="ab-top-grid">
        <div>
          <div class="ab-field-label">Year</div>
          <select id="air-year"><option value="">Select Year</option></select>
        </div>
        <div>
          <div class="ab-field-label">Make</div>
          <select id="air-make" disabled><option value="">Select Make</option></select>
        </div>
        <div>
          <div class="ab-field-label">Model</div>
          <select id="air-model" disabled><option value="">Select Model</option></select>
        </div>
        <div>
          <div class="ab-field-label">Drivetrain</div>
          <select id="air-drive" disabled><option value="">Select Drivetrain</option></select>
        </div>
        <div>
          <div class="ab-field-label">&nbsp;</div>
          <button id="air-check-fitment" type="button" class="ab-check-btn">Build My Kit</button>
        </div>
      </div>

      <div id="air-fitment-result" class="ab-status"></div>
    </div>

    <div id="air-builder-area" class="ab-builder-area">
      <div id="air-progress" class="ab-progress">
        <div class="ab-step" data-step="suspension"><div class="ab-step-kicker">Step 1</div><div class="ab-step-label">Suspension</div></div>
        <div class="ab-step" data-step="management"><div class="ab-step-kicker">Step 2</div><div class="ab-step-label">Management</div></div>
        <div class="ab-step" data-step="tank"><div class="ab-step-kicker">Step 3</div><div class="ab-step-label">Tank + Compressor</div></div>
        <div class="ab-step" data-step="addons"><div class="ab-step-kicker">Step 4</div><div class="ab-step-label">Add-Ons + Review</div></div>
      </div>

      <div id="air-summary-shell" class="ab-summary-shell">
        <div class="ab-summary-bar">
          <div class="ab-summary-item"><div class="ab-summary-label">Vehicle</div><div id="air-side-vehicle" class="ab-summary-value">Not selected</div></div>
          <div class="ab-summary-item"><div class="ab-summary-label">Suspension</div><div id="air-side-suspension" class="ab-summary-value">Not selected</div></div>
          <div class="ab-summary-item"><div class="ab-summary-label">Management</div><div id="air-side-management" class="ab-summary-value">Not selected</div></div>
          <div class="ab-summary-item"><div class="ab-summary-label">Tank + Compressor</div><div id="air-side-tank" class="ab-summary-value">Not selected</div></div>
          <div class="ab-summary-item"><div class="ab-summary-label">Add-Ons</div><div id="air-side-addons" class="ab-summary-value">None</div></div>
          <div class="ab-summary-total"><div class="ab-summary-label">Kit Total</div><div id="air-side-total" class="ab-summary-value">$0.00</div></div>
        </div>
      </div>

      <div id="air-slide-suspension" class="ab-glass ab-slide">
        <div class="ab-mobile-step">Step 1 of 4 • Suspension</div>
        <div class="ab-slide-title">Choose Suspension</div>
        <div class="ab-slide-sub">Select front, rear, both, or no suspension.</div>
        <div id="air-slide-error-suspension" class="ab-inline-error"></div>
        <div id="air-kit-grid" class="ab-grid"></div>
        <div id="air-suspension-summary" class="ab-summary-line"></div>
        <div class="ab-actions">
          <button id="air-to-management" type="button" class="ab-btn ab-btn-primary">Continue to Management</button>
        </div>
      </div>

      <div id="air-slide-management" class="ab-glass ab-slide">
        <div class="ab-mobile-step">Step 2 of 4 • Management</div>
        <div class="ab-slide-title">Select Management</div>
        <div class="ab-slide-sub">Choose a management system or continue without one.</div>
        <div id="air-slide-error-management" class="ab-inline-error"></div>
        <div id="air-management-grid" class="ab-grid"></div>
        <div id="air-management-summary" class="ab-summary-line"></div>
        <div class="ab-actions">
          <button id="air-back-to-suspension" type="button" class="ab-btn ab-btn-secondary">Back</button>
          <button id="air-to-tank" type="button" class="ab-btn ab-btn-primary">Continue to Tank + Compressor</button>
        </div>
      </div>

      <div id="air-slide-tank" class="ab-glass ab-slide">
        <div class="ab-mobile-step">Step 3 of 4 • Tank + Compressor</div>
        <div class="ab-slide-title">Select Tank + Compressor</div>
        <div class="ab-slide-sub">Choose the setup you want to pair with your build, or continue without one.</div>
        <div id="air-slide-error-tank" class="ab-inline-error"></div>
        <div id="air-tank-grid" class="ab-grid"></div>
        <div id="air-tank-summary" class="ab-summary-line"></div>
        <div class="ab-actions">
          <button id="air-back-to-management" type="button" class="ab-btn ab-btn-secondary">Back</button>
          <button id="air-to-addons" type="button" class="ab-btn ab-btn-primary">Continue to Add-Ons</button>
        </div>
      </div>

      <div id="air-slide-addons" class="ab-glass ab-slide">
        <div class="ab-mobile-step">Step 4 of 4 • Add-Ons + Review</div>
        <div class="ab-slide-title">Add Optional Upgrades</div>
        <div class="ab-slide-sub">Select any add-ons you want, then review the build.</div>
        <div id="air-addon-grid" class="ab-grid"></div>
        <div id="air-addon-summary" class="ab-summary-line"></div>
        <div class="ab-actions">
          <button id="air-back-to-tank" type="button" class="ab-btn ab-btn-secondary">Back</button>
          <button id="air-to-review" type="button" class="ab-btn ab-btn-primary">Review Build</button>
        </div>
      </div>

      <div id="air-slide-review" class="ab-glass ab-slide">
        <div class="ab-mobile-step">Review Your Build</div>
        <div class="ab-slide-title">Review Your Build</div>
        <div class="ab-slide-sub">Make sure everything looks right before adding it to cart.</div>

        <div class="ab-review ab-review-mobile-hide">
          <div class="ab-review-row"><div class="ab-review-label">Vehicle</div><div id="air-review-vehicle" class="ab-review-value">—</div></div>
          <div class="ab-review-row"><div class="ab-review-label">Suspension</div><div id="air-review-suspension" class="ab-review-value">—</div></div>
          <div class="ab-review-row"><div class="ab-review-label">Management</div><div id="air-review-management" class="ab-review-value">—</div></div>
          <div class="ab-review-row"><div class="ab-review-label">Tank + Compressor</div><div id="air-review-tank" class="ab-review-value">—</div></div>
          <div class="ab-review-row"><div class="ab-review-label">Add-Ons</div><div id="air-review-addons" class="ab-review-value">—</div></div>
        </div>

        <div class="ab-mobile-summary">
          <div class="ab-mobile-summary-title">Build Summary</div>
          <div class="ab-mobile-summary-row"><div class="ab-mobile-summary-label">Vehicle</div><div id="air-mobile-vehicle" class="ab-mobile-summary-value">—</div></div>
          <div class="ab-mobile-summary-row"><div class="ab-mobile-summary-label">Suspension</div><div id="air-mobile-suspension" class="ab-mobile-summary-value">—</div></div>
          <div class="ab-mobile-summary-row"><div class="ab-mobile-summary-label">Management</div><div id="air-mobile-management" class="ab-mobile-summary-value">—</div></div>
          <div class="ab-mobile-summary-row"><div class="ab-mobile-summary-label">Tank + Compressor</div><div id="air-mobile-tank" class="ab-mobile-summary-value">—</div></div>
          <div class="ab-mobile-summary-row"><div class="ab-mobile-summary-label">Add-Ons</div><div id="air-mobile-addons" class="ab-mobile-summary-value">—</div></div>
          <div class="ab-mobile-summary-row"><div class="ab-mobile-summary-label">Kit Total</div><div id="air-mobile-total" class="ab-mobile-summary-value">$0.00</div></div>
        </div>

        <div class="ab-actions">
          <button id="air-back-to-addons" type="button" class="ab-btn ab-btn-secondary">Back</button>
          <button id="air-add-to-cart" type="button" class="ab-btn ab-btn-primary">Add Build to Cart <span id="air-cart-price" class="ab-cart-price">$0.00</span></button>
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  
  "name": "Air Builder",
  "target": "section",
  "stylesheet": "air-builder.css",
  "javascript": "air-builder.js"
}
{% endschema %}
